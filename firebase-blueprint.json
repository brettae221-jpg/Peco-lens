{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user profiles and permissions",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Operator"] },
        "name": { "type": "string" },
        "dept": { "type": "string" },
        "appPosition": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "firstLogin": { "type": "boolean" },
        "accessibleModes": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["email", "role"]
    },
    "PMItem": {
      "title": "PM Item",
      "description": "Log of faulty parts for Preventive Maintenance",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "equipmentType": { "type": "string", "enum": ["Megajet", "Grasselli", "Vision", "Thermal", "General"] },
        "partName": { "type": "string" },
        "issueDescription": { "type": "string" },
        "severity": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "loggedBy": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Fixed"] },
        "aiReasoning": { "type": "string" },
        "modelUrl": { "type": "string" }
      },
      "required": ["timestamp", "equipmentType", "partName", "issueDescription", "loggedBy", "status"]
    },
    "PMEntry": {
      "title": "PM Entry",
      "description": "Shift-based preventive maintenance logs",
      "type": "object",
      "properties": {
        "source": { "type": "string", "enum": ["Belt Check", "Manual Add"] },
        "area": { "type": "string" },
        "subArea": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "Fixed"] },
        "assignedTo": { "type": "string" }
      },
      "required": ["source", "area", "description", "timestamp", "userId", "userEmail", "status"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Real-time communication message",
      "type": "object",
      "properties": {
        "senderEmail": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "image": { "type": "string" },
        "read": { "type": "boolean" }
      },
      "required": ["senderEmail", "text", "timestamp"]
    },
    "NewsPost": {
      "title": "News Post",
      "description": "Activity feed item",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "type": { "type": "string" },
        "textContent": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "likes": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId", "userEmail", "type", "textContent", "timestamp"]
    },
    "TestResult": {
      "title": "Test Result",
      "description": "Training test performance record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "testId": { "type": "string" },
        "testTitle": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "percentage": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "testId", "score", "timestamp"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Security and activity trail",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "severity": { "type": "string", "enum": ["info", "warning", "critical"] }
      },
      "required": ["userId", "action", "timestamp", "severity"]
    },
    "GalleryAsset": {
      "title": "Gallery Asset",
      "description": "Media asset library item",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["diagram", "model", "photo", "scan"] },
        "url": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "category": { "type": "string" }
      },
      "required": ["userId", "url", "type", "timestamp"]
    },
    "Machine": {
      "title": "Machine",
      "description": "Industrial machine state and telemetry",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["Operational", "Maintenance", "Fault"] },
        "health": { "type": "number" },
        "runtime": { "type": "number" },
        "sync": { "type": "string" }
      },
      "required": ["name", "status"]
    },
    "AICache": {
      "title": "AI Cache",
      "description": "Cached AI responses for offline fallback",
      "type": "object",
      "properties": {
        "promptHash": { "type": "string" },
        "response": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["promptHash", "response"]
    }
  },
  "firestore": {
    "/pm_items": {
      "schema": "PMItem",
      "description": "Faulty parts logs"
    },
    "/pmlist": {
      "schema": "PMEntry",
      "description": "Shift PM logs"
    },
    "/users": {
        "schema": "User",
        "description": "User profiles"
    },
    "/news_feed": {
      "schema": "NewsPost",
      "description": "Global activity feed"
    },
    "/test_results": {
      "schema": "TestResult",
      "description": "Training results"
    },
    "/audit_logs": {
      "schema": "AuditLog",
      "description": "Admin activity logs"
    },
    "/gallery_assets": {
      "schema": "GalleryAsset",
      "description": "User uploaded assets"
    },
    "/threads": {
      "schema": "object",
      "description": "Chat threads"
    },
    "/threads/{threadId}/messages": {
      "schema": "ChatMessage",
      "description": "Messages within a thread"
    },
    "/messages": {
      "schema": "ChatMessage",
      "description": "Direct chat messages"
    },
    "/alerts": {
      "schema": "ChatMessage",
      "description": "System alerts"
    },
    "/broadcasts": {
      "schema": "ChatMessage",
      "description": "Admin broadcasts"
    },
    "/machines": {
      "schema": "Machine",
      "description": "Live machine status"
    },
    "/ai_cache": {
      "schema": "AICache",
      "description": "Cached AI responses"
    },
    "/system/config": {
      "schema": "object",
      "description": "Global system configuration"
    },
    "/system_modules": {
      "schema": "object",
      "description": "App navigation module configuration"
    }
  }
}
